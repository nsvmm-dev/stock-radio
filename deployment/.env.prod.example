# Production API keys
# Copy this file to .env.prod and fill in the real values
# .env.prod is gitignored - never commit real keys

# LLM (choose one: claude recommended for production)
LLM_PROVIDER=claude
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=skip
# To use OpenAI instead:
# LLM_PROVIDER=openai
# ANTHROPIC_API_KEY=skip
# OPENAI_API_KEY=your_openai_key_here

# TTS (higher quality for production)
TTS_ENGINE=neural

# Stock data
JQUANTS_API_KEY=your_jquants_paid_api_key_here
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Groq (keep as fallback)
GROQ_API_KEY=your_groq_key_here
